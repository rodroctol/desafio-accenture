    {
      "name": "1. Teste Base",
      "item": [
        {
          "name": "1.1 Criar User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (pm.response.code === 201) {",
                  "    pm.environment.set(\"userID\", jsonData.userID);",
                  "    pm.environment.set(\"userName\", jsonData.username);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"user_{{$randomInt}}\",\n  \"password\": \"Senha@123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/Account/v1/User",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "Account",
                "v1",
                "User"
              ]
            }
          },
          "response": []
        },
